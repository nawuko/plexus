# Database Configuration

# REQUIRED: Database connection URL
# Plexus requires a DATABASE_URL environment variable to connect to the database.
# Supported formats:
#   - PostgreSQL: postgresql://username:password@host:port/database_name
#   - SQLite: sqlite:///path/to/database.sqlite

# Examples:
# Production PostgreSQL:
# DATABASE_URL=postgresql://user:pass@prod-db.example.com:5432/plexus

# Development PostgreSQL:
# DATABASE_URL=postgresql://plexus:plexus@localhost:5432/plexusdev

# Production SQLite:
# DATABASE_URL=sqlite:///var/lib/plexus/database.sqlite

# Development SQLite (in-memory for testing):
# DATABASE_URL=sqlite://:memory:

# Provider performance rolling window size per provider:model combo (default: 100)
# PLEXUS_PROVIDER_PERFORMANCE_RETENTION_LIMIT=100

# Encryption at Rest
# Optional: Set to encrypt sensitive data (API keys, OAuth tokens, provider credentials) in the database.
# Generate with: openssl rand -hex 32
# WARNING: If this key is lost, encrypted data cannot be recovered.
# If not set, data is stored in plaintext (backward compatible).
# ENCRYPTION_KEY=
